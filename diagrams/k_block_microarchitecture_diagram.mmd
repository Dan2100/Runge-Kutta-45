graph TB
    XIN["x_in"]
    YIN["y_in"]
    HIN["h"]

    subgraph KB["k_block Microarchitecture (Dormand-Prince)"]
        direction TB

        subgraph ST1["Stage 1"]
            F1["func\nk1 = f(x_in, y_in)"]
        end

        subgraph ST2["Stage 2"]
            S2X["fpu_fused\nx2 = C2*h + x_in"]
            S2M1["fpu_mul\nt1 = A21*k1"]
            S2Y["fpu_fused\ny2 = h*t1 + y_in"]
            F2["func\nk2 = f(x2, y2)"]
            S2M1 --> S2Y --> F2
            S2X --> F2
        end

        subgraph ST3["Stage 3"]
            S3X["fpu_fused\nx3 = C3*h + x_in"]
            S3M1["fpu_mul\nt1 = A31*k1"]
            S3A1["fpu_fused\nt2 = A32*k2 + t1"]
            S3Y["fpu_fused\ny3 = h*t2 + y_in"]
            F3["func\nk3 = f(x3, y3)"]
            S3M1 --> S3A1 --> S3Y --> F3
            S3X --> F3
        end

        subgraph ST4["Stage 4"]
            S4X["fpu_fused\nx4 = C4*h + x_in"]
            S4M1["fpu_mul\nt1 = A41*k1"]
            S4A1["fpu_fused\nt2 = A42*k2 + t1"]
            S4A2["fpu_fused\nt3 = A43*k3 + t2"]
            S4Y["fpu_fused\ny4 = h*t3 + y_in"]
            F4["func\nk4 = f(x4, y4)"]
            S4M1 --> S4A1 --> S4A2 --> S4Y --> F4
            S4X --> F4
        end

        subgraph ST5["Stage 5"]
            S5X["fpu_fused\nx5 = C5*h + x_in"]
            S5M1["fpu_mul\nt1 = A51*k1"]
            S5A1["fpu_fused\nt2 = A52*k2 + t1"]
            S5A2["fpu_fused\nt3 = A53*k3 + t2"]
            S5A3["fpu_fused\nt4 = A54*k4 + t3"]
            S5Y["fpu_fused\ny5 = h*t4 + y_in"]
            F5["func\nk5 = f(x5, y5)"]
            S5M1 --> S5A1 --> S5A2 --> S5A3 --> S5Y --> F5
            S5X --> F5
        end

        subgraph ST6["Stage 6"]
            S6X["fpu_fused\nx6 = 1.0*h + x_in"]
            S6M1["fpu_mul\nt1 = A61*k1"]
            S6A1["fpu_fused\nt2 = A62*k2 + t1"]
            S6A2["fpu_fused\nt3 = A63*k3 + t2"]
            S6A3["fpu_fused\nt4 = A64*k4 + t3"]
            S6A4["fpu_fused\nt5 = A65*k5 + t4"]
            S6Y["fpu_fused\ny6 = h*t5 + y_in"]
            F6["func\nk6 = f(x6, y6)"]
            S6M1 --> S6A1 --> S6A2 --> S6A3 --> S6A4 --> S6Y --> F6
            S6X --> F6
        end
    end

