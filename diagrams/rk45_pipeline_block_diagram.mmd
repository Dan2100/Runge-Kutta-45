%%{ init: { 'theme': 'base', 'themeVariables': { 'fontSize': '12px' } } }%%
graph TB
    XIN["x_in"]
    YIN["y_in"]
    HIN["h"]
    
    XIN --> KB["k_block<br/>(6 DP Stages)"]
    YIN --> KB
    HIN --> KB
    
    KB -->|k1‥k6| SOL["Solution<br/>Pipeline"]
    KB -->|k1‥k6| ERR["Error<br/>Pipeline"]
    HIN --> SOL
    YIN --> SOL
    HIN --> ERR
    
    SOL -->|y_n+1| YOUT["y_out"]
    ERR -->|error| ERROUT["err_out"]
    HIN --> XADD["X Update<br/>x + h"]
    XIN --> XADD
    XADD --> XOUT["x_out"]
    
    style KB fill:#d94a6b,stroke:#9e2d4a,color:#fff
    style SOL fill:#4a90d9,stroke:#2c5f8a,color:#fff
    style ERR fill:#e8a838,stroke:#b07d20,color:#fff
    style XADD fill:#50b86c,stroke:#357a48,color:#fff
