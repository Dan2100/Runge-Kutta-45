%% =============================================================================
%% rk45_compute_block_diagram.mmd — RK45 Compute Datapath Detail
%% =============================================================================
%% Shows the internal structure of rk45_step and rk45_stage, including
%% the FP units, ODE function, and the optimized pipelined/overlapped datapath.
%%
%% Phase A optimization (rk45_stage): Pipelined MAC feeds c*h then a[j]*k[j]
%%   back-to-back (1/cycle) into fp_mul pipeline, collects into buffer, then
%%   sequential accumulation. Post-MAC runs h*accum and x+c*h in parallel.
%%
%% Phase B optimization (rk45_step): After k6, launches k7 AND runs error
%%   accumulation (e[0..5]*k[0..5]) in parallel using separate FP units.
%%
%% Render: https://mermaid.live  or  mmdc -i rk45_compute_block_diagram.mmd -o rk45_compute.svg
%%
flowchart TB
    %% ── Inputs ───────────────────────────────────────────────────────────────
    xn(["xₙ"])
    yn(["yₙ"])
    h(["h"])
    ode_prog(["ODE Program\nprog_mem, const_regs, prog_len, result_reg"])

    %% ── rk45_step ────────────────────────────────────────────────────────────
    subgraph step ["rk45_step"]
        direction TB

        orch["Stage Orchestrator FSM\nCompute k1..k6, then launch k7 + error path"]

        subgraph stage ["rk45_stage (reused ×7)"]
            direction LR
            mac["Pipelined MAC (Phase A)\nCompute weighted stage sum"]
            post["Parallel Post-MAC\nBuild (x_stage, y_stage)"]
            ode["ode_engine (microcode)\nEvaluate k_s = f(x_stage, y_stage)"]
            mac --> post --> ode
        end

        overlap["Overlapped k7 + Error (Phase B)\nRun k7 and e1..e6 accumulation in parallel"]
        fold["Fold k7 Error Term\nAdd e7·k7 to partial error sum"]
        herr["Error Scaling\nerr_est = h · Σ(e_i·k_i)"]
        k7cap["k7 Capture\nProduce y_next and k7_out"]

        orch --> stage
        stage --> orch
        orch --> overlap
        overlap --> fold
        overlap --> k7cap
        fold --> herr
    end

    %% ── Outputs ──────────────────────────────────────────────────────────────
    yo(["y_next"])
    eo(["err_est"])
    ko(["k7_out"])

    %% ── Connections ──────────────────────────────────────────────────────────
    xn --> step
    yn --> step
    h --> step
    ode_prog --> stage
    k7cap --> yo
    k7cap --> ko
    herr --> eo
