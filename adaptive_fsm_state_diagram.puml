@startuml adaptive_fsm
title Adaptive FSM

skinparam state {
	BackgroundColor #EAF3FF
	BorderColor #2C5F8A
	FontColor #1C3550
}

[*] --> S_IDLE

state "S_IDLE\nrunning=0\nsm_flush=0\nsm_write_en=0\nsm_init=0" as S_IDLE
state "S_FLUSH\nrunning=1\nsm_flush=1\nsm_write_en=0\nsm_init=0\nwait_cnt=0" as S_FLUSH
state "S_COMPUTE\nrunning=1\nsm_flush=0\nsm_write_en=0\nsm_init=0\nwait RK latency" as S_COMPUTE
state "S_UPDATE\nrunning=1\nsm_flush=0\nsm_write_en=1\nsm_init=1\nwrite back + adapt" as S_UPDATE
state "S_DONE\nrunning=0\ndone_reg=1\nsm_flush=0\nsm_write_en=0\nsm_init=0" as S_DONE

S_IDLE --> S_FLUSH : RKS detect\ninst(14:12)="010"\ninst(6:0)="0001100"\nstep_cnt:=0\ntarget_steps:=n_steps
S_IDLE --> S_IDLE : otherwise

S_FLUSH --> S_COMPUTE : next clock

S_COMPUTE --> S_COMPUTE : wait_cnt < COMPUTE_WAIT-1\nwait_cnt := wait_cnt + 1
S_COMPUTE --> S_UPDATE : wait_cnt = COMPUTE_WAIT-1

S_UPDATE --> S_FLUSH : sc_accepted='0'\n(reject, retry with smaller h)
S_UPDATE --> S_FLUSH : sc_accepted='1' and\nstep_cnt+1 < target_steps\n(step_cnt := step_cnt + 1)
S_UPDATE --> S_DONE : sc_accepted='1' and\nstep_cnt+1 >= target_steps\n(step_cnt := step_cnt + 1)

S_DONE --> S_IDLE : init cmd detect\ninst(14:12)="000"\ninst(6:0)="0001100"\ndone_reg := 0
S_DONE --> S_DONE : otherwise

@enduml