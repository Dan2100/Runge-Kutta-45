%%{ init: { 'theme': 'base', 'themeVariables': { 'fontSize': '12px' } } }%%
graph TB
    INST["inst<31:0>"]
    CLK["clock"]
    
    INST --> CTRL["Control Unit"]
    INST --> REG["Reg File"]
    INST --> FSM["Adaptive FSM"]
    CLK --> CTRL
    CLK --> REG
    CLK --> MEM["Memory"]
    CLK --> RK["RKMod1<br/>RK45"]
    CLK --> SC["step_ctrl"]
    CLK --> FSM
    
    CTRL -->|flush,<br/>write_en, init| MUX["Control MUX"]
    FSM -->|sm_flush,<br/>sm_write_en, sm_init| MUX
    CTRL -->|addr| MEM
    
    MUX -->|flush, write_en, init| MEM
    REG -->|cont| MEM
    
    MEM -->|x, y, h| RK
    MEM -->|h, tol| SC
    
    RK -->|x_out, y_out| MEM
    RK -->|err_out| SC
    RK -->|err_out| ERROUT["err_out"]
    
    SC -->|h_new| MEM
    SC -->|accepted| MEM
    SC -->|accepted| FSM
    
    MEM -->|n_steps| FSM
    
    RK -->|x_out| XOUT["x_out"]
    RK -->|y_out| YOUT["y_out"]
    
    FSM -->|done| DONEOUT["done"]
    CTRL -->|initial| INITOUT["initial"]
    
    style CTRL fill:#4a90d9,stroke:#2c5f8a,color:#fff
    style REG fill:#50b86c,stroke:#357a48,color:#fff
    style MEM fill:#e8a838,stroke:#b07d20,color:#fff
    style RK fill:#d94a6b,stroke:#9e2d4a,color:#fff
    style SC fill:#9b59b6,stroke:#6c3483,color:#fff
    style FSM fill:#1abc9c,stroke:#148f77,color:#fff
    style MUX fill:#ff9f40,stroke:#d97d2e,color:#fff
